# SEEKR local GCS defaults
# Copy this file to .env for local server/scripts, or export values in your shell.
# Set SEEKR_LOAD_DOTENV=false to ignore .env loading.
# SEEKR_ENV_FILE=.env

# API/client ports
PORT=8787
SEEKR_API_PORT=8787
SEEKR_CLIENT_PORT=5173

# Local data directory for mission events, snapshots, evidence, and replay manifests.
SEEKR_DATA_DIR=data

# Optional internal rehearsal auth.
# When set, mutating routes require Authorization: Bearer <token> or x-seekr-token: <token>.
# Do not commit real tokens.
# Add SEEKR_INTERNAL_TOKEN in your local .env only when needed.

# Optional expected source health config.
# CSV form: sourceAdapter:channel:droneA|droneB
# SEEKR_EXPECTED_SOURCES=mavlink:telemetry:drone-1,ros2-slam:map

# Local AI controls.
SEEKR_AI_PROVIDER=ollama
SEEKR_OLLAMA_URL=http://127.0.0.1:11434
SEEKR_OLLAMA_MODEL=llama3.2:latest
SEEKR_OLLAMA_TIMEOUT_MS=20000
# SEEKR_AI_PROVIDER=rules
